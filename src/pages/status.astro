---
// src/pages/status.astro
//
// Bookmarkable status page showing the results of the most recent
// link-check run. Reads link-check-summary.json (written by
// scripts/check-links.ts) at build time.
//
// This page is informational only — it does not require action.
// Indeterminate jobs remain live on the job board; this page exists
// so the curator can spot-check them at her own pace.

import { readFileSync } from "fs";
import { join } from "path";
import Navigation from "../components/Navigation.astro";

interface IndeterminateJob {
  company: string;
  title: string;
  link: string;
}

interface LinkCheckSummary {
  ranAt: string;
  active: number;
  inactive: number;
  indeterminate: number;
  skipped: number;
  total: number;
  indeterminateJobs: IndeterminateJob[];
}

let summary: LinkCheckSummary | null = null;
let loadError: string | null = null;

try {
  const summaryPath = join(process.cwd(), "link-check-summary.json");
  summary = JSON.parse(readFileSync(summaryPath, "utf-8"));
} catch {
  loadError =
    "No link-check-summary.json found yet. This file is generated by the link checker — run it at least once to populate this page.";
}

// Format the timestamp in a readable, unambiguous way, and compute how
// long ago the run happened so staleness is obvious at a glance.
function formatRanAt(iso: string): { absolute: string; relative: string } {
  const ranAt = new Date(iso);
  const now = new Date();
  const diffMs = now.getTime() - ranAt.getTime();
  const diffMinutes = Math.floor(diffMs / 60_000);
  const diffHours = Math.floor(diffMinutes / 60);
  const diffDays = Math.floor(diffHours / 24);

  let relative: string;
  if (diffMinutes < 1) {
    relative = "just now";
  } else if (diffMinutes < 60) {
    relative = `${diffMinutes} minute${diffMinutes === 1 ? "" : "s"} ago`;
  } else if (diffHours < 24) {
    relative = `${diffHours} hour${diffHours === 1 ? "" : "s"} ago`;
  } else {
    relative = `${diffDays} day${diffDays === 1 ? "" : "s"} ago`;
  }

  const absolute = ranAt.toLocaleString("en-US", {
    weekday: "short",
    year: "numeric",
    month: "short",
    day: "numeric",
    hour: "numeric",
    minute: "2-digit",
    timeZoneName: "short",
  });

  return { absolute, relative };
}

const STALE_THRESHOLD_DAYS = 10;
const isStale = summary
  ? (new Date().getTime() - new Date(summary.ranAt).getTime()) / 86_400_000 >
    STALE_THRESHOLD_DAYS
  : false;

const timing = summary ? formatRanAt(summary.ranAt) : null;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<meta name="robots" content="noindex" />
		<title>Link Check Status — South Lake Tahoe Job Board</title>
	</head>
	<body>
		<main>
			<Navigation />
			<h1>Link Check Status</h1>
			<p class="subtitle">
				Results from the most recent automated check of job listing links.
			</p>

			{loadError && <div class="empty-state">{loadError}</div>}

			{summary && timing && (
				<>
					<section class:list={["run-info", { stale: isStale }]}>
						<p class="run-label">Last run</p>
						<p class="run-time">
							{timing.absolute}
							<span class="run-relative">({timing.relative})</span>
						</p>
						{isStale && (
							<p class="stale-warning">
								This is more than {STALE_THRESHOLD_DAYS} days old. The link
								checker may not be running on schedule — worth checking the
								GitHub Actions workflow.
							</p>
						)}
					</section>

					<section class="counts">
						<div class="count-card count-active">
							<p class="count-number">{summary.active}</p>
							<p class="count-label">Active</p>
						</div>
						<div class="count-card count-indeterminate">
							<p class="count-number">{summary.indeterminate}</p>
							<p class="count-label">Indeterminate</p>
						</div>
						<div class="count-card count-inactive">
							<p class="count-number">{summary.inactive}</p>
							<p class="count-label">Inactive (excluded)</p>
						</div>
						<div class="count-card count-skipped">
							<p class="count-number">{summary.skipped}</p>
							<p class="count-label">No URL to check</p>
						</div>
					</section>

					<p class="total-line">{summary.total} job listings checked in total.</p>

					<hr class="section-divider" />

					<section class="indeterminate-section">
						<h2>Indeterminate links</h2>
						<p class="section-note">
							These links returned a result the checker couldn't classify with
							confidence — a slow response, a login wall, or a site that
							blocks automated requests. They remain visible on the job board.
							Worth a quick manual look when you have a moment, but nothing
							here requires immediate action.
						</p>

						{summary.indeterminateJobs.length === 0 ? (
							<p class="empty-state">
								None right now — every checked link returned a clear result.
							</p>
						) : (
							<ul class="job-list">
								{summary.indeterminateJobs.map((job) => (
									<li class="job-item">
										<span class="job-company">{job.company}</span>
										<span class="job-title">{job.title}</span>
										<a href={job.link} target="_blank" rel="noopener noreferrer">
											Check link →
										</a>
									</li>
								))}
							</ul>
						)}
					</section>
				</>
			)}
		</main>
	</body>
</html>

<style>
	:global(html) {
		font-family: system-ui, sans-serif;
		line-height: 1.5;
		color-scheme: dark;
	}

	:global(body) {
		margin: 0;
		padding: 0;
		background-color: #1a1a1a;
		color: #e0e0e0;
	}

	main {
		max-width: 900px;
		margin: 0 auto;
		padding: 1.5rem;
		min-height: 100vh;
	}

	h1 {
		text-align: center;
		color: #ffffff;
		margin-bottom: 1rem;
		font-size: 2rem;
		font-weight: 700;
	}

	.subtitle {
		text-align: center;
		color: #b8b8b8;
		margin: 0 auto 2rem auto;
		font-size: 1.1rem;
		max-width: 600px;
		line-height: 1.6;
	}

	.run-info {
		background: #2a2a2a;
		border: 1px solid #3a3a3a;
		border-radius: 12px;
		padding: 1.25rem 1.5rem;
		margin-bottom: 1.5rem;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
	}

	.run-info.stale {
		border-color: #d8a13a;
	}

	.run-label {
		margin: 0;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: #999;
	}

	.run-time {
		margin: 0.25rem 0 0;
		font-size: 1.1rem;
		color: #e0e0e0;
	}

	.run-relative {
		color: #999;
		font-weight: normal;
		margin-left: 0.4rem;
	}

	.stale-warning {
		margin: 0.75rem 0 0;
		color: #d8a13a;
		font-size: 0.9rem;
	}

	.counts {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0.75rem;
		margin-bottom: 0.75rem;
	}

	.count-card {
		background: #2a2a2a;
		border: 1px solid #3a3a3a;
		border-radius: 12px;
		padding: 1rem 0.75rem;
		text-align: center;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
	}

	.count-number {
		margin: 0;
		font-size: 1.75rem;
		font-weight: 700;
	}

	.count-active .count-number {
		color: #5fb87a;
	}

	.count-indeterminate .count-number {
		color: #d8a13a;
	}

	.count-inactive .count-number {
		color: #888;
	}

	.count-skipped .count-number {
		color: #5a9de8;
	}

	.count-label {
		margin: 0.25rem 0 0;
		font-size: 0.78rem;
		color: #999;
	}

	.total-line {
		color: #999;
		font-size: 0.9rem;
		margin: 0 0 1.5rem;
		text-align: center;
	}

	.section-divider {
		border: none;
		border-top: 1px solid #3a3a3a;
		margin: 2rem auto;
	}

	.indeterminate-section h2 {
		color: #ffffff;
		font-size: 1.25rem;
		font-weight: 600;
		margin: 0 0 0.5rem;
	}

	.section-note {
		color: #b8b8b8;
		font-size: 0.95rem;
		line-height: 1.6;
		margin: 0 0 1.25rem;
		max-width: 65ch;
	}

	.job-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.job-item {
		background: #2a2a2a;
		border: 1px solid #3a3a3a;
		border-radius: 12px;
		padding: 0.9rem 1.25rem;
		display: flex;
		align-items: baseline;
		gap: 0.6rem;
		flex-wrap: wrap;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
	}

	.job-company {
		font-weight: 600;
		color: #ffffff;
	}

	.job-title {
		color: #b8b8b8;
	}

	.job-item a {
		margin-left: auto;
		color: #5a9de8;
		text-decoration: none;
		font-size: 0.9rem;
		white-space: nowrap;
	}

	.job-item a:hover {
		text-decoration: underline;
	}

	.empty-state {
		color: #b8b8b8;
		background: #2a2a2a;
		border: 1px solid #3a3a3a;
		border-radius: 12px;
		padding: 1.25rem 1.5rem;
	}

	@media (max-width: 768px) {
		main {
			padding: 1rem;
		}

		h1 {
			font-size: 1.75rem;
		}

		.subtitle {
			font-size: 1rem;
			margin-bottom: 1.5rem;
		}

		.counts {
			grid-template-columns: repeat(2, 1fr);
		}

		.job-item a {
			margin-left: 0;
		}
	}
</style>
